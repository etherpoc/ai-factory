{
  "name": "universal-agent-factory",
  "version": "0.0.1",
  "private": true,
  "description": "Universal Agent Factory — multi-agent system that turns a natural-language request into runnable games, web apps, mobile apps, desktop apps, CLIs and APIs.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "bin": {
    "uaf": "./bin/uaf.js"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "nock": "^14.0.13",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.3",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@inquirer/prompts": "^8.4.2",
    "commander": "^14.0.3",
    "date-fns": "^4.1.0",
    "p-limit": "^7.3.0",
    "picocolors": "^1.1.1",
    "pino": "^10.3.1",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
