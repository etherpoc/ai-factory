# Anthropic API key used by all agents (required)
ANTHROPIC_API_KEY=sk-ant-...

# Default model overrides (optional). Leave unset to use per-role defaults
# (Sonnet 4.6 for director/architect/programmer, Haiku 4.5 for tester/reviewer/evaluator).
# UAF_DEFAULT_MODEL forces a single model for every role; set it only when
# you explicitly want that (e.g. debugging, Opus opt-in).
# UAF_DEFAULT_MODEL=claude-sonnet-4-6

# Orchestration limits (optional)
# UAF_MAX_ITERATIONS=8
# UAF_CIRCUIT_BREAKER_STRIKES=3

# Workspace root (defaults to <repo>/workspace)
# UAF_WORKSPACE_ROOT=./workspace

# Log level: trace | debug | info | warn | error
# UAF_LOG_LEVEL=info

# ---------------------------------------------------------------------------
# Phase 11.a — external asset providers (optional)
#
# Required when a recipe's agents.optional includes `artist` or `sound`.
# Without these, the CLI skips creative generation and falls back to the
# Phase 6 behavior (generated projects ship without real images/audio).
# ---------------------------------------------------------------------------

# Replicate (SDXL for image generation): https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_...

# ElevenLabs (sound-generation for BGM + SFX): https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_...

# Default per-run asset budget (USD). CLI flag --asset-budget-usd overrides.
# Set to 0 to disable asset generation without uninstalling the provider.
# DEFAULT_ASSET_BUDGET_USD=2.00
